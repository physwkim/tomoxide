/target
# the GUI is workspace-excluded (own lock), so it builds into its own target
/crates/tomoxide-gui/target
**/*.rs.bk
Cargo.lock.bak

# build artefacts from the CUDA backend (nvcc output)
*.ptx
*.cubin
*.fatbin
*.o

# editor / OS noise
.DS_Store
.vscode/
.idea/

# reconstruction outputs and sample data
/data
*.h5
*.tiff
*.tif
*.zarr

# ...but test fixtures are required INPUTS, not outputs — keep them tracked even
# though their extensions match the output-ignore rules above.
!crates/tomoxide/tests/fixtures/*.h5
!crates/tomoxide/tests/fixtures/*.tiff
!crates/tomoxide/tests/fixtures/*.tif
!crates/tomoxide/tests/fixtures/*.zarr
